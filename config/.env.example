PORT=3000

# Comma-separated list of valid code words (uppercase)
VALID_CODE_WORDS=SUMMER

# Simple IP rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# SMTP settings
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@example.com
SMTP_PASS=replace_with_app_password
SMTP_FROM=info@example.com
SMTP_FROM_NAME=Cordiant Promo Support

# Manager dashboard auth
MANAGER_DASHBOARD_PASSWORD=replace_with_strong_password
MANAGER_DASHBOARD_TOKEN_SECRET=replace_with_long_random_secret
MANAGER_SESSION_TTL_MS=28800000
